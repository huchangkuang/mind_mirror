#!/bin/bash
# 阿里云 FC Custom Runtime 启动脚本
# 文档: https://help.aliyun.com/document_detail/74756.html

# 设置环境变量
export NODE_ENV=production
export PORT=9000
export HOSTNAME=0.0.0.0

# 确保 Next.js 能正确识别请求头
export NEXT_TELEMETRY_DISABLED=1

# 进入应用目录（FC 运行时挂载到 /code）
cd /code

# 启动 Next.js standalone 服务器
exec node server.js
