# Mind Mirror Monorepo — 环境变量示例（根目录）

# ── Web (apps/web) ──
# 开发环境 API 地址（未配置时 dev 默认 http://localhost:3001）
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# 前端请求超时（毫秒）
# NEXT_PUBLIC_API_TIMEOUT_MS=10000

# AccessToken 过期前多久触发主动刷新（毫秒，默认 120000）
# NEXT_PUBLIC_AUTH_REFRESH_SKEW_MS=120000

# 生产：若 Nginx 同域反代 /api/v1/*，可留空 NEXT_PUBLIC_API_BASE_URL
# 若 API 独立域名，构建时设置：
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# ── API (apps/api) — 复制 apps/api/.env.example 为 apps/api/.env ──
# PORT=3001
# DATABASE_URL=mysql://...
# JWT_SECRET=...
# FRONTEND_ORIGIN=http://localhost:3000
