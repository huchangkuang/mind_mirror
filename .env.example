# 数据库等（按你方实际配置）
# DATABASE_URL=...

# 前端请求外部后端 API（未配置时生产默认同源；开发环境回退到 http://localhost:3001）
# 生产环境建议显式配置为你的站点域名，例如：
# NEXT_PUBLIC_API_BASE_URL=https://mmirror.qiexuxing.top

# 前端请求超时（毫秒）
# NEXT_PUBLIC_API_TIMEOUT_MS=10000

# AccessToken 过期前多久触发主动刷新（毫秒，默认 120000，适配 accessToken=15m）
# NEXT_PUBLIC_AUTH_REFRESH_SKEW_MS=120000

# 生产默认 Cookie 带 Secure（仅 HTTPS）。若用 HTTP 访问（如 ECS 直连 IP），须关闭：
# COOKIE_SECURE=false

# 可选：构建/部署时写入，便于 GET /api/deploy-info 对照 Git
# APP_GIT_COMMIT=969a04e
